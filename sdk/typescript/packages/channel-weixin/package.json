{
  "name": "@dotcraft/channel-weixin",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "description": "DotCraft external channel adapter for WeChat (iLink) using dotcraft-wire",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "dotcraft-channel-weixin": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "README_ZH.md"
  ],
  "scripts": {
    "start": "node dist/cli.js adapter_config.json",
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build && node dist/cli.js adapter_config.json",
    "test": "npm run build",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "dotcraft-wire": "*",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/qrcode-terminal": "^0.12.2",
    "typescript": "^5.7.0"
  }
}
