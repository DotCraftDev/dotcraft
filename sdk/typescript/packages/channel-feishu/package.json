{
  "name": "@dotcraft/channel-feishu",
  "version": "0.1.3",
  "private": true,
  "type": "module",
  "description": "DotCraft external channel adapter for Feishu/Lark using dotcraft-wire",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "dotcraft-channel-feishu": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "README_ZH.md"
  ],
  "scripts": {
    "start": "node dist/cli.js --workspace .",
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build && node dist/cli.js --workspace .",
    "test": "npm run build && node --test dist/feishu-transcript.test.js dist/event-handler.test.js dist/card-action-dedup.test.js dist/module.test.js dist/config.test.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "dotcraft-wire": "*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0"
  }
}
