<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>DotCraft</RootNamespace>

    <!-- Version Information -->
    <AssemblyVersion>0.1.6</AssemblyVersion>
    <Version>0.1.6</Version>
    <AssemblyName>dotcraft</AssemblyName>
    <AssemblyTitle>DotCraft</AssemblyTitle>
    <ProductName>DotCraft</ProductName>
    <ApplicationIcon>Resources\favicon.ico</ApplicationIcon>

    <!-- Emit compiler generated files for debugging -->
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>

    <!-- Tells DotCraft.Gen to emit the ModuleRegistrations class in this assembly -->
    <DotCraftGenerateModuleRegistrations>true</DotCraftGenerateModuleRegistrations>
  </PropertyGroup>

  <!-- Optional module switches (set to false to exclude from build) -->
  <PropertyGroup>
    <IncludeModuleUnity Condition="'$(IncludeModuleUnity)' == ''">true</IncludeModuleUnity>
    <IncludeModuleAGUI Condition="'$(IncludeModuleAGUI)' == ''">true</IncludeModuleAGUI>
    <IncludeModuleAPI Condition="'$(IncludeModuleAPI)' == ''">true</IncludeModuleAPI>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)'=='Release'">
    <DebugSymbols>False</DebugSymbols>
    <DebugType>None</DebugType>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="Resources\favicon.ico" />
    <EmbeddedResource Include="Resources\Templates\**\*" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="TextCopy" Version="6.2.1" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\DotCraft.Core\DotCraft.Core.csproj" />
    <ProjectReference Include="..\DotCraft.Automations\DotCraft.Automations.csproj" />
    <ProjectReference Include="..\DotCraft.Unity\DotCraft.Unity.csproj" Condition="'$(IncludeModuleUnity)' == 'true'" />
    <ProjectReference Include="..\DotCraft.Agui\DotCraft.Agui.csproj" Condition="'$(IncludeModuleAGUI)' == 'true'" />
    <ProjectReference Include="..\DotCraft.Api\DotCraft.Api.csproj" Condition="'$(IncludeModuleAPI)' == 'true'" />
  </ItemGroup>

  <!-- Source Generator Reference -->
  <ItemGroup>
    <ProjectReference Include="..\DotCraft.Gen\DotCraft.Gen.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
  </ItemGroup>

  <ItemGroup>
    <CompilerVisibleProperty Include="DotCraftGenerateModuleRegistrations" />
  </ItemGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleToAttribute">
      <_Parameter1>DotCraft.App.Tests</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>

</Project>
