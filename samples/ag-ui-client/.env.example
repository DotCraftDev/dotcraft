# DotCraft AG-UI proxy (used by /api/dotcraft)
# Must match DotCraft AgUi.Host and AgUi.Port (default 5100) and AgUi.Path (default /ag-ui)
DOTCRAFT_AGUI_URL=http://127.0.0.1:5100/ag-ui

# Optional: Chat suggestions below input. "always" | "after-first-message" | "before-first-message" | "disabled"
NEXT_PUBLIC_SUGGESTIONS_AVAILABLE=always
